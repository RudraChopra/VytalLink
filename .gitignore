# ---------------------------------------------------------------------------
# VytalLink .gitignore
# Never commit secrets, footage, model weights, databases with real data,
# logs, caches, or virtual environments.
# ---------------------------------------------------------------------------

# Secrets / environment
.env
.env.*
!.env.example
*.secret
*.pem
*.key
config/secrets*.toml
config/secrets*.yaml

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Test / coverage / type caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/

# Databases (real data must never be committed)
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm
data/database/*
!data/database/.gitkeep

# Event media / footage / snapshots / clips
data/events/*
!data/events/.gitkeep
data/clips/*
!data/clips/.gitkeep
*.mp4
*.avi
*.mkv
*.mov
*.jpg
*.jpeg
*.png
!docs/**/*.png
!src/vytallink/dashboard/static/**/*.png

# Model weights & generated TensorRT engines
models/*
!models/.gitkeep
*.pt
*.pth
*.onnx
*.engine
*.plan
*.trt
*.weights

# Logs
logs/*
!logs/.gitkeep
*.log

# Runtime / PID files
*.pid
run/

# Ultralytics prediction/run outputs (footage; never commit)
runs/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/

# Soak / diagnostics output (metrics only — never images). Reusable harness
# scripts live in scripts/ (committed); their output stays here, ignored.
/diagnostics/
