# ===========================================================================
# VytalLink configuration example.
#
# Copy to `.env` and edit. NEVER commit `.env` (it is gitignored).
# Secrets (camera password, webhook secret) must only ever live in `.env`.
#
# For tonight's simulated Phase 1 build, the defaults below work as-is.
# ===========================================================================

# ---- Core service ---------------------------------------------------------
# Environment: development | testing | production
VYTALLINK_ENV=development
# Bind address. 0.0.0.0 exposes the dashboard on your LAN.
VYTALLINK_HOST=0.0.0.0
VYTALLINK_PORT=5050
# Leave blank to use the default: data/database/vytallink.db
VYTALLINK_DATABASE_PATH=
VYTALLINK_LOG_LEVEL=INFO

# ---- Vision / camera ------------------------------------------------------
# VISION_MODE: simulation | file | rtsp
#   simulation -> no camera opened; deterministic simulated source (default)
#   file       -> CAMERA_SOURCE is a path to a local video file
#   rtsp       -> CAMERA_SOURCE is an RTSP URL or host (see docs/hardware_needed.md)
VISION_MODE=simulation
# For rtsp: e.g. rtsp://CAMERA_HOST:554/Streaming/Channels/101
# For file: e.g. /home/rchopra/VytalLink/data/clips/sample.mp4
CAMERA_SOURCE=
CAMERA_USERNAME=
CAMERA_PASSWORD=

# ---- Detector / model -----------------------------------------------------
# DETECTOR_MODE: simulation | yolo | tensorrt
#   simulation -> deterministic simulated detector (default)
#   yolo       -> Ultralytics YOLO model at MODEL_PATH (requires CUDA PyTorch)
#   tensorrt   -> TensorRT engine (only after the real model is validated)
DETECTOR_MODE=simulation
MODEL_PATH=
CONFIDENCE_THRESHOLD=0.55
PROCESS_EVERY_N_FRAMES=3
IMAGE_SIZE=416
# Comma-separated class names that count as fall evidence.
FALL_CLASS_NAMES=fall,fallen,lying,fall_detected,person_fall

# ---- Fall event timing ----------------------------------------------------
# How long sustained fall evidence must persist before an event confirms.
FALL_CONFIRM_SECONDS=2.0
# How long evidence must be absent before a confirmed event resolves.
FALL_CLEAR_SECONDS=3.0
# Minimum gap between alerts (prevents alert storms across events).
ALERT_COOLDOWN_SECONDS=30

# ---- Event media (privacy: off by default) --------------------------------
SAVE_EVENT_SNAPSHOTS=false
SAVE_EVENT_CLIPS=false

# ---- Wearable -------------------------------------------------------------
# WEARABLE_MODE: simulation  (real wearable not yet selected; see docs)
WEARABLE_MODE=simulation
WEARABLE_SAMPLE_SECONDS=5.0

# ---- Alerts ---------------------------------------------------------------
# Console alerts always available in dev. Webhook is optional; if WEBHOOK_URL
# is set, a signed POST is sent on each confirmed event.
WEBHOOK_URL=
WEBHOOK_SECRET=
WEBHOOK_TIMEOUT_SECONDS=5.0
CONSOLE_ALERTS_ENABLED=true

# ---- Monitoring -----------------------------------------------------------
# Real-time loop tick interval (seconds) used only in file/rtsp modes.
MONITOR_LOOP_INTERVAL=0.5
# Warn when disk usage on the data volume exceeds this percentage.
DISK_WARNING_PERCENT=90
