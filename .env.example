# ===========================================================================
# VytalLink configuration example.
#
# Copy to `.env` and edit. NEVER commit `.env` (it is gitignored).
# Secrets (camera password, webhook secret) must only ever live in `.env`.
#
# For tonight's simulated Phase 1 build, the defaults below work as-is.
# ===========================================================================

# ---- Core service ---------------------------------------------------------
# Environment: development | testing | production
VYTALLINK_ENV=development
# Bind address. 0.0.0.0 exposes the dashboard on your LAN.
VYTALLINK_HOST=0.0.0.0
VYTALLINK_PORT=5050
# Leave blank to use the default: data/database/vytallink.db
VYTALLINK_DATABASE_PATH=
VYTALLINK_LOG_LEVEL=INFO

# ---- Vision / camera ------------------------------------------------------
# VISION_MODE: simulation | file | rtsp | http_mjpeg
#   simulation -> no camera opened; deterministic simulated source (default)
#   file       -> CAMERA_SOURCE is a path to a local video file
#   rtsp       -> a live RTSP camera (see docs/hardware_needed.md)
#   http_mjpeg -> a remote HTTP camera relay (MJPEG stream preferred, snapshot
#                 polling fallback). Used to consume a Jetson camera-relay
#                 endpoint from this host. See CAMERA_HTTP_* below.
VISION_MODE=simulation
#
# RTSP can be configured two ways (CAMERA_SOURCE wins if both are set):
#   1) a full URL in CAMERA_SOURCE (file path for VISION_MODE=file), or
#   2) the component fields CAMERA_HOST / CAMERA_PORT / CAMERA_STREAM_PATH.
# The username/password are ALWAYS kept separate so they never appear in a
# logged source string — the URL is assembled in memory and only ever logged
# in redacted form (rtsp://***REDACTED***@host:port/path).
CAMERA_SOURCE=
CAMERA_HOST=
CAMERA_PORT=554
# e.g. Streaming/Channels/101 (Hikvision)  |  cam/realmonitor?channel=1&subtype=0 (Dahua)
CAMERA_STREAM_PATH=
CAMERA_USERNAME=
CAMERA_PASSWORD=
#
# HTTP relay camera (VISION_MODE=http_mjpeg). MJPEG is preferred; the snapshot
# URL is a polling fallback. The optional bearer token is sent ONLY via the
# Authorization header — it is never logged, returned, or placed in a URL, and
# only a redacted scheme://host:port form of the endpoint is ever surfaced.
CAMERA_HTTP_STREAM_URL=
CAMERA_HTTP_SNAPSHOT_URL=
CAMERA_HTTP_BEARER_TOKEN=

# ---- Detector / model -----------------------------------------------------
# DETECTOR_MODE: simulation | yolo | tensorrt
#   simulation -> deterministic simulated detector (default)
#   yolo       -> Ultralytics YOLO model at MODEL_PATH (requires CUDA PyTorch)
#   tensorrt   -> TensorRT engine (only after the real model is validated)
DETECTOR_MODE=simulation
# Path to the trained fall model. Leave blank to use models/fall_detection.pt.
MODEL_PATH=
CONFIDENCE_THRESHOLD=0.55
PROCESS_EVERY_N_FRAMES=3
IMAGE_SIZE=416
# Comma-separated class names that count as fall evidence.
FALL_CLASS_NAMES=fall,fallen,lying,fall_detected,person_fall
# Experimental posture-transition filter (reproduces the legacy DTS-lite idea).
# OFF by default so a sustained 'fallen' posture always counts as a fall (no
# missed falls). When ON it rejects "already lying down" only when no prior
# upright was seen; full fall-vs-slow-lie discrimination needs the velocity-based
# DTS (future work). true | false.
DETECTOR_REQUIRE_TRANSITION=false

# ---- Fall event timing ----------------------------------------------------
# How long sustained fall evidence must persist before an event confirms.
FALL_CONFIRM_SECONDS=2.0
# How long evidence must be absent before a confirmed event resolves.
FALL_CLEAR_SECONDS=3.0
# Minimum gap between alerts (prevents alert storms across events).
ALERT_COOLDOWN_SECONDS=30

# ---- Event media (privacy: off by default) --------------------------------
SAVE_EVENT_SNAPSHOTS=false
SAVE_EVENT_CLIPS=false

# ---- Wearable -------------------------------------------------------------
# WEARABLE_MODE: simulation  (real wearable not yet selected; see docs)
WEARABLE_MODE=simulation
WEARABLE_SAMPLE_SECONDS=5.0

# ---- Alerts ---------------------------------------------------------------
# Master switch. false -> no alert provider is built; events are still recorded
# but nothing is delivered (handy during live hardware tests). true (default)
# uses the providers below.
ALERTS_ENABLED=true
# Console alerts always available in dev. Webhook is optional; if WEBHOOK_URL
# is set, a signed POST is sent on each confirmed event.
WEBHOOK_URL=
WEBHOOK_SECRET=
WEBHOOK_TIMEOUT_SECONDS=5.0
CONSOLE_ALERTS_ENABLED=true

# ---- Monitoring -----------------------------------------------------------
# Simulation heartbeat tick interval (seconds). Live modes (file/rtsp/http_mjpeg)
# are NOT throttled by this — they pace by DETECT_MAX_FPS below.
MONITOR_LOOP_INTERVAL=0.5
# Warn when disk usage on the data volume exceeds this percentage.
DISK_WARNING_PERCENT=90

# ---- Live detection pacing (file/rtsp/http_mjpeg) -------------------------
# Inference runs on the FRESHEST frame, paced to at most this many per second
# (no fixed per-frame sleep — a fast model is not throttled).
DETECT_MAX_FPS=12
# A frame older than this (seconds) is intentionally dropped BEFORE inference so
# the system always works on fresh frames, never a stale backlog.
DETECT_MAX_FRAME_AGE_SECONDS=1.0

# ---- HTTP relay / dashboard frame (bandwidth + latency) -------------------
# The dashboard/relay JPEG copy is downscaled to fit RELAY_WIDTH×RELAY_HEIGHT
# (aspect preserved) and capped at RELAY_MAX_FPS. This ONLY affects the
# dashboard/relay copy — never the full-resolution detection input. On the
# Jetson relay host these shrink the bytes sent to the Mac; 0 disables downscale.
RELAY_WIDTH=960
RELAY_HEIGHT=540
RELAY_JPEG_QUALITY=70
RELAY_MAX_FPS=10

# ---- Dashboard live video (privacy-sensitive; OFF by default) -------------
# When true (development only), the dashboard exposes the live camera feed.
# The dashboard itself has no authentication, so WITHOUT a token this makes the
# feed visible to ANY device on the LAN. No footage is ever written to disk.
DASHBOARD_LIVE_VIDEO=false
# Optional shared secret. When set, /api/camera/stream and /api/camera/snapshot.jpg
# require `Authorization: Bearer <token>` (the dashboard prompts for it). Strongly
# recommended whenever DASHBOARD_LIVE_VIDEO=true on a shared network. Leave blank
# for an open feed. The token is never logged, returned, or placed in a URL.
DASHBOARD_VIDEO_TOKEN=
# Development-only: overlay the detector's bounding boxes / class / confidence
# plus detector FPS, frame age, and fall-state on the live feed (uses the
# detector's existing result — never re-runs YOLO). OFF by default.
DASHBOARD_SHOW_DETECTIONS=false
